  );

  const renderWindow = (offsetX) => (
    <group position={[offsetX, 5, 0]} key={`window-${offsetX}`}>
      <mesh><boxGeometry args={[2.5, 1.5, 0.12]} /><meshStandardMaterial color="#374151" /></mesh>

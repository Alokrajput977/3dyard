    </group>
  );

  const renderDoor = (offsetX) => (
    <mesh position={[offsetX, 2.5, 0]} key={`door-${offsetX}`} castShadow>
      <boxGeometry args={[2, 5, 0.1]} />
      <meshStandardMaterial color="#4B5563" roughness={0.8} />
